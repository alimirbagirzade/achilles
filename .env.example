# Achilles Trader AI — environment template
# Copy to .env and adjust. NEVER commit .env.

# ===========================================================================
# === LLM BACKEND — ÖNERİLEN: OpenAI =======================================
# ===========================================================================
#
#  "auto"   → OpenAI API key varsa OpenAI kullan; yoksa Ollama'ya geç (varsayılan)
#  "openai" → Sadece OpenAI API  [ÖNERILEN — daha hızlı, daha güçlü]
#  "ollama" → Sadece yerel Ollama (internet gerektirmez, ücretsiz)
#
ACHILLES_LLM_BACKEND=auto

# --- OpenAI (önerilen backend) ---
# sk-... anahtarını buraya yaz → sistem otomatik OpenAI'ye geçer
ACHILLES_OPENAI_API_KEY=          # sk-...  (boşsa OpenAI devre dışı)
ACHILLES_OPENAI_MODEL=gpt-4o-mini
# Alternatifler: gpt-4o, gpt-4-turbo, gpt-3.5-turbo
# Azure / yerel OpenAI-uyumlu API için base URL değiştir:
# ACHILLES_OPENAI_BASE_URL=https://api.openai.com/v1

# ===========================================================================
# === OLLAMA (yerel / ücretsiz — OpenAI yoksa fallback) =====================
# ===========================================================================

ACHILLES_OLLAMA_HOST=http://127.0.0.1:11434
ACHILLES_EMBED_MODEL=nomic-embed-text

# === RAM PROFILE: pick ONE ACHILLES_LLM_MODEL ===============================
#  8 GB  (varsayılan) -> qwen3:4b   (~2.5GB, thinking+no_think destekli)
#  16 GB              -> qwen3:8b
#  32 GB+             -> qwen3:14b
ACHILLES_LLM_MODEL=qwen3:4b
# ACHILLES_LLM_MODEL=qwen3:8b
# ACHILLES_LLM_MODEL=qwen3:14b
# ===========================================================================

# --- LoRA eğitimi için MLX model (yalnızca macOS Apple Silicon) ---
ACHILLES_MLX_BASE_MODEL=models/mlx/Qwen3-4B-4bit

# --- Embedding / offline behavior ---
ACHILLES_ALLOW_FAKE_EMBEDDINGS=true

# --- RAG / chunking ---
ACHILLES_RAG_TOP_K=6
ACHILLES_CHUNK_SIZE=1200
ACHILLES_CHUNK_OVERLAP=200

# --- Storage (relative to project root unless absolute) ---
# ACHILLES_SQLITE_PATH=storage/sqlite/achilles_trader_ai.db
# ACHILLES_CHROMA_PATH=vector_db/chroma

# --- Trading defaults (spec section 14) ---
ACHILLES_DEFAULT_MARKET=XAUUSD
ACHILLES_DEFAULT_TIMEFRAME=15m

# --- Auto-LoRA Pipeline ---
# false = sadece manuel tetikleme (varsayılan, güvenli)
# true  = her ACHILLES_AUTO_LORA_CHECK_INTERVAL_MIN dakikada otomatik gate kontrolü
ACHILLES_AUTO_LORA_ENABLED=false
ACHILLES_AUTO_LORA_MIN_CARDS=20
ACHILLES_AUTO_LORA_CHECK_INTERVAL_MIN=60
ACHILLES_AUTO_LORA_EVAL_THRESHOLD=0.5

# --- Logging ---
ACHILLES_LOG_LEVEL=INFO

# --- Web UI (achilles-web) ---
ACHILLES_WEB_HOST=127.0.0.1          # yalnız localhost; ağa açmak için 0.0.0.0 + token
ACHILLES_WEB_PORT=8765
# Token YOKSA kimlik doğrulama KAPALIDIR. Ağa açmadan önce güçlü değer ata:
#   ACHILLES_API_TOKEN=$(openssl rand -hex 32)
ACHILLES_API_TOKEN=
ACHILLES_RATE_LIMIT_PER_MIN=120
# Yükleme uçlarına (PDF/CSV) ayrı, daha sıkı limit — ağ DoS / disk doldurma.
ACHILLES_UPLOAD_RATE_LIMIT_PER_MIN=20
# Upload boyut limiti (PDF + CSV). Yükseltmek için artır, sunucuyu yeniden başlat.
# Not: dosya tamamen RAM'e okunur — 8GB makinede çok büyük değer önerilmez.
ACHILLES_MAX_UPLOAD_MB=50

# --- AĞA AÇARKEN (uzak/kiralık CPU) — lokal kullanımda boş/false bırak ---
# Host-header koruması (boş = kısıt yok). Ağa açarken alan adını/IP'yi ver:
ACHILLES_TRUSTED_HOSTS=
# TLS (reverse proxy/HTTPS) arkasındaysan true → Strict-Transport-Security başlığı:
ACHILLES_HSTS_ENABLED=false
# Adım-adım sertleştirme checklist: SECURITY.md
