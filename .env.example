# Achilles Trader AI — environment template
# Copy to .env and adjust. NEVER commit .env.

# ===========================================================================
# === LLM BACKEND — YEREL (Ollama). PAY-PER-TOKEN API KULLANILMAZ. ===========
# ===========================================================================
# Bu proje LOKAL-ÖNCELİKLİDİR: çalışma-zamanı LLM hattı tamamen YERELDİR (Ollama).
# Pay-per-token API (OpenAI/Anthropic vb.) VARSAYILAN DEĞİLDİR ve gerekmez. AI yardımı
# aylık ABONELİKLİ araçlarla (Claude Code/Codex) yapılır — faturalı API anahtarı ile DEĞİL.
#
#  "ollama" → Sadece yerel Ollama (ÖNERİLEN — anahtar/internet gerektirmez, ücretsiz)
#  "auto"   → OpenAI key VARSA OpenAI, yoksa Ollama (key boş = ollama gibi davranır)
#  "openai" → Sadece OpenAI-uyumlu uç (OPSİYONEL; bu projede önerilmez)
#
ACHILLES_LLM_BACKEND=ollama

# --- OpenAI-uyumlu API (OPSİYONEL — varsayılan KAPALI; boş bırak) ---
# Bu proje API GEREKTİRMEZ. Anahtar boşsa OpenAI tamamen devre dışıdır (sistem Ollama
# ile çalışır). Yalnız bilinçli, yerel-OpenAI-uyumlu bir uca bağlanacaksan doldur.
ACHILLES_OPENAI_API_KEY=          # boş = devre dışı (ÖNERİLEN)
ACHILLES_OPENAI_MODEL=gpt-4o-mini
# ACHILLES_OPENAI_BASE_URL=https://api.openai.com/v1

# ===========================================================================
# === OLLAMA (yerel / ücretsiz — VARSAYILAN backend) ========================
# ===========================================================================

ACHILLES_OLLAMA_HOST=http://127.0.0.1:11434
ACHILLES_EMBED_MODEL=nomic-embed-text
# Modeli sorgu sonrası ne kadar yüklü tutsun. Aynı anda LoRA EĞİTİMİ varsa "0" (hemen
# boşalt → ~7GB çakışma/OOM önlenir). Büyük makinede "5m" ardışık sorguyu hızlandırır.
ACHILLES_OLLAMA_KEEP_ALIVE=30s

# === RAM PROFILE: pick ONE ACHILLES_LLM_MODEL ===============================
#  8 GB  (varsayılan) -> qwen3:4b   (~2.5GB, thinking+no_think destekli)
#  16 GB              -> qwen3:8b
#  32 GB+             -> qwen3:14b
ACHILLES_LLM_MODEL=qwen3:4b
# ACHILLES_LLM_MODEL=qwen3:8b
# ACHILLES_LLM_MODEL=qwen3:14b
# ===========================================================================

# --- LoRA eğitimi için MLX model (yalnızca macOS Apple Silicon) ---
ACHILLES_MLX_BASE_MODEL=models/mlx/Qwen3-4B-4bit

# --- Embedding / offline behavior ---
ACHILLES_ALLOW_FAKE_EMBEDDINGS=true

# --- RAG / chunking ---
ACHILLES_RAG_TOP_K=6
ACHILLES_CHUNK_SIZE=1200
ACHILLES_CHUNK_OVERLAP=200

# --- Storage (relative to project root unless absolute) ---
# ACHILLES_SQLITE_PATH=storage/sqlite/achilles_trader_ai.db
# ACHILLES_CHROMA_PATH=vector_db/chroma

# --- Trading defaults (spec section 14) ---
ACHILLES_DEFAULT_MARKET=XAUUSD
ACHILLES_DEFAULT_TIMEFRAME=15m

# --- Auto-LoRA Pipeline ---
# false = sadece manuel tetikleme (varsayılan, güvenli)
# true  = her ACHILLES_AUTO_LORA_CHECK_INTERVAL_MIN dakikada otomatik gate kontrolü
ACHILLES_AUTO_LORA_ENABLED=false
ACHILLES_AUTO_LORA_MIN_CARDS=20
ACHILLES_AUTO_LORA_CHECK_INTERVAL_MIN=60
ACHILLES_AUTO_LORA_EVAL_THRESHOLD=0.5

# --- Logging ---
ACHILLES_LOG_LEVEL=INFO

# --- Sentez aynalama (synthesis mirror) ---
# Üretilen her sentez makalesi (reports/synthesis/sentez_*.md) ayrıca bu dizine
# kopyalanır (best-effort; hata sentez üretimini kırmaz). Boş/yorumlu bırakılırsa
# aynalama KAPALIDIR (varsayılan). Yol değişikliği sunucu/döngü yeniden başlatınca
# etkinleşir (ayar başlangıçta okunur). Örnek:
# ACHILLES_SYNTHESIS_MIRROR_DIR=C:\Users\KULLANICI\Desktop\RAG Kaynak\Sentez Makelesi

# --- Web UI (achilles-web) ---
ACHILLES_WEB_HOST=127.0.0.1          # yalnız localhost; ağa açmak için 0.0.0.0 + token
ACHILLES_WEB_PORT=8765
# Token YOKSA kimlik doğrulama KAPALIDIR. Ağa açmadan önce güçlü değer ata:
#   ACHILLES_API_TOKEN=$(openssl rand -hex 32)
ACHILLES_API_TOKEN=
ACHILLES_RATE_LIMIT_PER_MIN=120
# Yükleme uçlarına (PDF/CSV) ayrı, daha sıkı limit — ağ DoS / disk doldurma.
ACHILLES_UPLOAD_RATE_LIMIT_PER_MIN=20
# Upload boyut limiti (PDF + CSV). Yükseltmek için artır, sunucuyu yeniden başlat.
# Not: dosya tamamen RAM'e okunur — 8GB makinede çok büyük değer önerilmez.
ACHILLES_MAX_UPLOAD_MB=50

# --- AĞA AÇARKEN (uzak/kiralık CPU) — lokal kullanımda boş/false bırak ---
# Host-header koruması (boş = kısıt yok). Ağa açarken alan adını/IP'yi ver:
ACHILLES_TRUSTED_HOSTS=
# TLS (reverse proxy/HTTPS) arkasındaysan true → Strict-Transport-Security başlığı:
ACHILLES_HSTS_ENABLED=false
# Adım-adım sertleştirme checklist: SECURITY.md

# ===========================================================================
# === RLM MOTOR ADAPTER (opsiyonel alexzhang13/rlm) =========================
# ===========================================================================
# Varsayilan native: ek paket GEREKMEZ, OpenAI GEREKMEZ. alexzhang OPSIYONEL.
# Opsiyonel paketi kur: uv sync --extra rlm   (kurulu degilse native calisir)
ACHILLES_RLM_ENGINE_PROVIDER=native          # native | alexzhang
ACHILLES_RLM_PRODUCTION_MODE=true            # uretimde local-exec/shell/network/fs-write YASAK
ACHILLES_RLM_ALEXZHANG_ENABLED=false         # opsiyonel motor; varsayilan KAPALI
ACHILLES_RLM_ALEXZHANG_BACKEND=anthropic     # anthropic | local_openai_compatible (OpenAI degil)
ACHILLES_RLM_ALEXZHANG_MODEL=                # bossa anthropic_model'e duser (hardcode yok)
ACHILLES_RLM_ALEXZHANG_ENVIRONMENT=docker    # docker | ipython | local (uretimde 'local' yasak)
ACHILLES_RLM_ALEXZHANG_ALLOW_LOCAL_EXEC=false
# Anthropic runtime gerekiyorsa (yalniz alexzhang/anthropic backend'inde) — GERCEK KEY COMMIT ETME:
# ANTHROPIC_API_KEY=
