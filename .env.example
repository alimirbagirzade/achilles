# Achilles Trader AI — environment template
# Copy to .env and adjust. NEVER commit .env.

# --- Local LLM (Ollama) ---
ACHILLES_OLLAMA_HOST=http://localhost:11434
ACHILLES_EMBED_MODEL=nomic-embed-text

# --- LoRA eğitimi için HuggingFace model (Ollama formatı değil!) ---
# 8GB : mlx-community/Qwen2.5-Coder-1.5B-Instruct-4bit  (~1.9GB)
# 16GB: mlx-community/Qwen2.5-Coder-3B-Instruct-4bit
ACHILLES_MLX_BASE_MODEL=mlx-community/Qwen2.5-Coder-1.5B-Instruct-4bit

# === RAM PROFILE: pick ONE ACHILLES_LLM_MODEL ===============================
# The 7B model needs ~6GB RAM and is unreliable on 8GB machines (model + the
# embedding model do not co-reside). Choose the model that fits your hardware.
#
#  8 GB  (current default) -> qwen2.5-coder:3b   (~1.9GB, fast, fits w/ embed)
#  16 GB                   -> qwen2.5-coder:7b   (already pulled)
#  32 GB+ (future upgrade) -> qwen2.5-coder:14b  (best quality)
#
# When you switch to a 32GB machine:  ollama pull qwen2.5-coder:14b
#   then set ACHILLES_LLM_MODEL below to qwen2.5-coder:14b and restart.
ACHILLES_LLM_MODEL=qwen2.5-coder:3b
# ACHILLES_LLM_MODEL=qwen2.5-coder:7b     # 16GB
# ACHILLES_LLM_MODEL=qwen2.5-coder:14b    # 32GB+
# ===========================================================================

# --- Embedding / offline behavior ---
# true  = if Ollama is unreachable, fall back to deterministic FAKE embeddings
#         (offline dev / tests). false = hard-fail when Ollama is down.
ACHILLES_ALLOW_FAKE_EMBEDDINGS=true

# --- RAG / chunking ---
ACHILLES_RAG_TOP_K=6
ACHILLES_CHUNK_SIZE=1200
ACHILLES_CHUNK_OVERLAP=200

# --- Storage (relative to project root unless absolute) ---
# ACHILLES_SQLITE_PATH=storage/sqlite/achilles_trader_ai.db
# ACHILLES_CHROMA_PATH=vector_db/chroma

# --- Trading defaults (spec section 14) ---
ACHILLES_DEFAULT_MARKET=XAUUSD
ACHILLES_DEFAULT_TIMEFRAME=15m

# --- Auto-LoRA Pipeline ---
# false = sadece manuel tetikleme (varsayılan, güvenli)
# true  = her ACHILLES_AUTO_LORA_CHECK_INTERVAL_MIN dakikada otomatik gate kontrolü
ACHILLES_AUTO_LORA_ENABLED=false
ACHILLES_AUTO_LORA_MIN_CARDS=20
ACHILLES_AUTO_LORA_CHECK_INTERVAL_MIN=60
ACHILLES_AUTO_LORA_EVAL_THRESHOLD=0.5

# --- Logging ---
ACHILLES_LOG_LEVEL=INFO

# --- Web UI (achilles-web) ---
ACHILLES_WEB_HOST=127.0.0.1          # yalnız localhost; ağa açmak için 0.0.0.0 + token
ACHILLES_WEB_PORT=8765
ACHILLES_API_TOKEN=                   # boş = yerel mod (token gerekmez). Ağa açarsan ZORUNLU.
ACHILLES_RATE_LIMIT_PER_MIN=120
# Upload boyut limiti (PDF + CSV). Yükseltmek için artır, sunucuyu yeniden başlat.
# Not: dosya tamamen RAM'e okunur — 8GB makinede çok büyük değer önerilmez.
ACHILLES_MAX_UPLOAD_MB=50
