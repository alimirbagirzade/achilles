# Achilles Trader AI — environment template
# Copy to .env and adjust. NEVER commit .env.

# --- Local LLM (Ollama) ---
ACHILLES_OLLAMA_HOST=http://localhost:11434
ACHILLES_LLM_MODEL=qwen2.5-coder:7b
ACHILLES_EMBED_MODEL=nomic-embed-text

# --- Embedding backend ---
# "ollama" = use Ollama embeddings (requires Ollama running + model pulled)
# "fake"   = deterministic hash embeddings (offline / tests; no external deps)
ACHILLES_EMBED_BACKEND=ollama

# --- Chunking ---
ACHILLES_CHUNK_SIZE=1200
ACHILLES_CHUNK_OVERLAP=200

# --- Defaults (see spec section 14) ---
ACHILLES_DEFAULT_MARKET=XAUUSD
ACHILLES_DEFAULT_TIMEFRAME=15m
