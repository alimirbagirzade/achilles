# uv — lock dosyası BİLEREK commit'lenir (tekrarlanabilirlik + CI cache).

# Env / secrets
.env
.env.*
!.env.example

# Tooling caches
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Data & generated artifacts (keep dir structure via .gitkeep)
data/papers/raw_pdf/*
data/papers/extracted_text/*
data/papers/metadata/*
data/training/raw/*
data/training/cleaned/*
data/training/jsonl/*
data/market/raw/*
data/market/processed/*
