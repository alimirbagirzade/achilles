models/adapters/*
models/evals/*
reports/papers/*
reports/papers/mastery/*
reports/training/*
reports/backtests/*
reports/evals/*
# Sentez makaleleri makineye özel üretilir → commit edilmez (audit GAP fix)
reports/synthesis/*
# Agent runtime gözlemcisi (Phase 1) — koşu başına JSONL günlükleri (runtime)
reports/agent_runs/*
# RLM koşu raporları — koşu başına JSON (runtime çıktısı; achilles rlm-answer üretir)
reports/rlm_runs/*
# RLM motor trajektori logları (opsiyonel alexzhang motoru; runtime + olası hassas içerik)
reports/rlm/trajectories/*
# Lokal eğitim-denetim raporları (Phase 5A) — report-only çıktılar (runtime)
reports/local_training_orchestrator/*

# But keep the .gitkeep placeholders
!**/.gitkeep

# LoRA — büyük çıktılar commit edilmez
data/lora/raw/
data/lora/approved/
data/lora/review_needed/
data/lora/rejected/
data/lora_sft/*.jsonl
# Echo feedback — KULLANICI DÜZELTME METNİ içerir (app/feedback/echo.py:237).
# Diğer data/ alt dizinleri tek tek sayıldığı için bu atlanmıştı → kullanıcının
# yazdığı metin sessizce commit'lenebilirdi. .gitkeep `!**/.gitkeep` ile korunur.
data/feedback/*.jsonl
outputs/
checkpoints/
adapters/
# AMA: RLM motor-adapter KAYNAK paketi (LoRA eğitim çıktısı DEĞİL) izlenmeli — yoksa
# 'adapters/' kuralı app/rlm/adapters/* kaynak dosyalarını sessizce commit dışı bırakır.
# Yalnız .py kaynağı geri-dahil; __pycache__/*.pyc ignore'da KALIR (genel '!**' onu ezerdi).
!app/rlm/adapters/
!app/rlm/adapters/*.py
